  command = $PRE_LINK && /home/caroulder/TestSymCC/symcc/simple32build/sym++  $FLAGS  $LINK_FLAGS $in  -o $TARGET_FILE $LINK_PATH $LINK_LIBRARIES && $POST_BUILD
  description = Linking CXX executable $TARGET_FILE
  restat = $RESTAT


#############################################
# Rule for compiling CXX files.

rule CXX_COMPILER__lli-child-target
  depfile = $DEP_FILE
  deps = gcc
  command = /home/caroulder/TestSymCC/symcc/simple32build/sym++  $DEFINES $INCLUDES $FLAGS -MD -MT $out -MF $DEP_FILE -o $out -c $in
  description = Building CXX object $out


